{
  "name": "stingle-web",
  "version": "0.0.0",
  "description": "End-to-end encrypted Stingle Photos client for the web",
  "private": true,
  "license": "GPL-3.0-only",
  "keywords": [
    "stingle",
    "photos",
    "end-to-end-encryption",
    "privacy",
    "pwa"
  ],
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc -b && vite build",
    "dev": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:browser": "playwright test",
    "test:live-auth": "vitest run --config vitest.live.config.ts",
    "typecheck": "tsc -b --pretty false"
  },
  "dependencies": {
    "@scure/bip39": "2.2.0",
    "heic-to": "^1.4.2",
    "libsodium-wrappers-sumo": "0.8.4",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/node": "24.10.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "fake-indexeddb": "6.2.5",
    "typescript": "7.0.2",
    "vite": "8.1.5",
    "vite-plugin-pwa": "1.3.0",
    "vitest": "4.1.10"
  }
}
